# --- Database ---
DATABASE_URL=postgresql+psycopg://heritage:heritage@localhost:5432/heritage_lens

# --- Auth ---
SECRET_KEY=change-this-to-a-random-64-char-string
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- CORS ---
FRONTEND_ORIGIN=http://localhost:3000

# --- Storage: pick ONE provider and fill in its block ---
STORAGE_PROVIDER=cloudinary   # cloudinary | s3

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# AWS S3 (only used if STORAGE_PROVIDER=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_S3_REGION=ap-south-1
